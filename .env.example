# Vite public base: default in vite.config is `./` (works in iGEM subfolders). Use `/` for site-root hosting.
# VITE_BASE=/

# Optional: production CDN for static files (see `igemStatic()` in `src/content/igemAssets.ts`).
# Bundled placeholders use `src/assets/placeholders/*.svg` (`placeholderAssets.ts`), not CDN.
VITE_IGEM_STATIC_BASE=https://static.igem.wiki/teams/2026/pekinghsc/assets
VITE_IGEM_VIDEO_BASE=https://video.igem.org/videos
